{
  "name": "mastermind-control-plane",
  "version": "0.0.3",
  "private": true,
  "scripts": {
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "dev": "node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start": "node dist/main",
    "start:dev": "node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "test": "node ./node_modules/jest/bin/jest.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"{src,apps,libs,test}/**/*.ts\"",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"src/**/*.ts\"",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate deploy",
    "prisma:studio": "node ./node_modules/prisma/build/index.js studio",
    "prisma:seed": "node ./node_modules/ts-node/dist/bin.js prisma/seed.ts"
  },
  "prisma": {
    "seed": "node ./node_modules/ts-node/dist/bin.js prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.0",
    "@prisma/client": "^5.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0"
  }
}
