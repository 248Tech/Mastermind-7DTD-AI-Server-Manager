# Copy to infra/.env and set values before running in production.
# docker compose reads this file automatically when run from the infra/ directory.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=mastermind
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mastermind
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Auth secrets (CHANGE THESE IN PRODUCTION) ────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_AGENT_SECRET=change-me-in-production

# ── Ports ─────────────────────────────────────────────────────────────────────
CP_PORT=3001
WEB_PORT=3000

# ── Web build arg (must match the public URL users see in their browser) ──────
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:3001
